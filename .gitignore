# Secrets and local environment
.env

# Streamlit secrets (keep the template, ignore the real file)
.streamlit/secrets.toml

# Local credential files (Gmail OAuth client + cached token, etc.)
# Keep the directory and its README, ignore everything else inside.
secrets/*
!secrets/README.md

# Virtual environment
.venv/

# Python caches and bytecode
__pycache__/
*.py[cod]
*.pyc

# Test, type-check, and lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Coverage reports
.coverage
.coverage.*
coverage.xml
htmlcov/

# macOS
.DS_Store

# Local Claude Code preview/run config (machine-specific paths)
.claude/
