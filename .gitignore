# Secrets and local environment
.env

# Local credential files (Gmail OAuth client + cached token, etc.)
# Keep the directory and its README, ignore everything else inside.
secrets/*
!secrets/README.md

# Virtual environment
.venv/

# Python caches and bytecode
__pycache__/
*.py[cod]
*.pyc

# Test, type-check, and lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage reports
.coverage
.coverage.*
coverage.xml
htmlcov/

# macOS
.DS_Store
