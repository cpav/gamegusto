# GameGusto environment variables.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# Variable NAMES only are documented here — never commit real values.

# --- Required ---
# AWS region hosting the Bedrock model and the DynamoDB table.
AWS_REGION=
# Bedrock base model id or cross-Region inference-profile id for Claude Sonnet
# (e.g. a `global.anthropic.claude-sonnet-4-6-...` inference profile).
BEDROCK_MODEL_ID=
# Tavily API key used for metadata enrichment and autocomplete.
TAVILY_API_KEY=
# DynamoDB table name backing memory (records, platforms, sessions).
DYNAMODB_TABLE_NAME=

# --- Optional ---
# Extended-thinking token budget for the Bedrock Converse call (default 3000).
BEDROCK_REASONING_BUDGET_TOKENS=

# --- Optional: Gmail purchase-email integration (read-only) ---
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
GMAIL_REDIRECT_URI=
