# GameGusto environment variables.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# Variable NAMES only are documented here — never commit real values.

# --- Required ---
# AWS region hosting the Bedrock AgentCore resources.
AWS_REGION=
# Bedrock AgentCore agent identifier and alias.
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
# Tavily API key used for metadata enrichment and autocomplete.
TAVILY_API_KEY=

# --- Optional: Xbox platform integration ---
# Both must be set to enable the Xbox record source.
XBOX_CLIENT_ID=
XBOX_CLIENT_SECRET=

# --- Optional: Gmail purchase-email integration (read-only) ---
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
GMAIL_REDIRECT_URI=
