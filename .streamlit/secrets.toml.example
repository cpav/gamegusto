# GameGusto — Streamlit secrets template.
# Copy to .streamlit/secrets.toml for local runs, or paste these keys into the
# Streamlit Community Cloud app's "Secrets" box. Names only here — never commit
# real values (.streamlit/secrets.toml is git-ignored).

# --- Required: AWS for Bedrock + DynamoDB ---
AWS_REGION = "eu-north-1"
# Access key for the least-privilege `gamegusto` IAM user (Bedrock InvokeModel +
# DynamoDB on the gamegusto table). The hosted app can't use a local AWS profile.
AWS_ACCESS_KEY_ID = "..."
AWS_SECRET_ACCESS_KEY = "..."

# Bedrock inference-profile id for the Claude Sonnet model used by the agent.
BEDROCK_MODEL_ID = "eu.anthropic.claude-sonnet-4-6"

# DynamoDB table backing memory (records, platforms, sessions).
DYNAMODB_TABLE_NAME = "gamegusto"

# --- Required: Tavily (web search + enrichment) ---
TAVILY_API_KEY = "..."

# --- Optional ---
# BEDROCK_REASONING_BUDGET_TOKENS = "3000"
# Gmail is intentionally NOT configured on the hosted app (token stays local).
